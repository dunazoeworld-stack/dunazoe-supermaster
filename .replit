modules = ["nodejs-20", "web", "bash", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Core Microservices"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/core/frontend && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Core Microservices"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "chmod +x start-services.sh && bash start-services.sh"

[workflows.workflow.metadata]
outputType = "console"

