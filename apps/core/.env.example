# ================================================================
# DUNAZOE OS — MASTER ENVIRONMENT VARIABLES
# Copy to each service as .env and fill in real values
# ================================================================

# ── DATABASE ──────────────────────────────────────────────────
DATABASE_URL=postgresql://dunazoe_user:your_password@localhost:5432/dunazoe_db

# ── SECURITY (CHANGE ALL OF THESE IN PRODUCTION) ──────────────
JWT_SECRET=dunazoe_jwt_secret_min_32_chars_change_in_production
INTERNAL_SECRET=dunazoe_internal_secret_change_in_production
BCRYPT_ROUNDS=12
SESSION_DAYS=7

# ── PAYSTACK ──────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ── STRIPE (for USD payments) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── SHIPBUBBLE (logistics API) ────────────────────────────────
SHIPBUBBLE_API_KEY=your_shipbubble_api_key
SHIPBUBBLE_BASE_URL=https://api.shipbubble.com/v1

# ── TERMII / BULKSMS (SMS/WhatsApp) ──────────────────────────
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=DUNAZOE
WHATSAPP_BUSINESS_TOKEN=your_whatsapp_token

# ── GATEWAY ───────────────────────────────────────────────────
PORT=3000
ALLOWED_ORIGINS=https://dunazoe.com,https://app.dunazoe.com,http://localhost:3000
NODE_ENV=production

# ── SERVICE PORTS ─────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:4001
USER_SERVICE_URL=http://localhost:4002
VENDOR_SERVICE_URL=http://localhost:4003
PRODUCT_SERVICE_URL=http://localhost:4004
INVENTORY_SERVICE_URL=http://localhost:4005
ORDER_SERVICE_URL=http://localhost:4006
ESCROW_SERVICE_URL=http://localhost:4007
FRAUD_SERVICE_URL=http://localhost:4008
WALLET_SERVICE_URL=http://localhost:4009
THRIFT_SERVICE_URL=http://localhost:4010
TRUST_SERVICE_URL=http://localhost:4011
LOAN_SERVICE_URL=http://localhost:4012
COMMISSION_SERVICE_URL=http://localhost:4013
AI_SERVICE_URL=http://localhost:4014

# ── BUSINESS RULES ────────────────────────────────────────────
PLATFORM_FEE_PCT=0.10
AI_FEE_PCT=0.015
DELIVERY_COMMISSION_PCT=0.02
COPYTRADER_COMMISSION=0.06
MILESTONE_EVERY=100
MILESTONE_BONUS_NGN=5000
PAYOUT_CYCLE_DAYS=14
AJO_SURCHARGE_PCT=0.10
AJO_SURCHARGE_WEEKS=2
LOAN_INTEREST_RATE=0.05
LOAN_MIN_TRUST_SCORE=40
THRIFT_MIN=1000
THRIFT_INTEREST=0.05
MIN_DEPOSIT_NGN=100
PLATFORM_MARGIN=0.15

# ── FRAUD RULES ────────────────────────────────────────────────
FRAUD_HIGH_RISK_AMOUNT=500000
FRAUD_SUSPICIOUS_AMOUNT=200000
FRAUD_SUSPICIOUS_QTY=50
FRAUD_MAX_ORDERS_PER_HOUR=5

# ── NEW SERVICES (Phase 5-8) ──────────────────────────────────
PAYMENT_SERVICE_URL=http://localhost:4015
DISPUTE_SERVICE_URL=http://localhost:4016
NOTIFICATION_SERVICE_URL=http://localhost:4017
LOGISTICS_SERVICE_URL=http://localhost:4018

# WhatsApp/SMS channels
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=DUNAZOE
FRONTEND_URL=https://dunazoe.com
DISPUTE_EVIDENCE_HOURS=24
AGENT_ACCEPT_MINUTES=30

# ── NEW SERVICES (KYC + Reconciliation + Reliability) ─────────
KYC_SERVICE_URL=http://localhost:4023
RECONCILIATION_SERVICE_URL=http://localhost:4024
RELIABILITY_SERVICE_URL=http://localhost:4025

# ── UPDATE #93 — INFRASTRUCTURE ───────────────────────────────
# PgBouncer (use port 5433 for pooled connections in production)
PGBOUNCER_URL=postgresql://dunazoe_user:dunazoe_pass@localhost:5433/dunazoe_db

# Chaos engineering (NEVER enable in production)
CHAOS_ENABLED=false

# SSL monitoring
DOMAIN_CHECK_HOSTS=dunazoe.com,api.dunazoe.com

# Multi-region DR
DR_REGION_URL=

# FX rate (approximate, use live API in production)
USD_TO_NGN_RATE=1600

# Nigeria network resilience
OFFLINE_QUEUE_MAX_SIZE=10000
NETWORK_RETRY_ATTEMPTS=5

# Cost governance thresholds
SMS_COST_ALERT_NGN=50000
GATEWAY_COST_ALERT_NGN=200000

# Traffic surge threshold (ratio vs baseline)
SURGE_THRESHOLD_RATIO=3.0

# ── UPDATES #93-#96 SERVICE URLS ─────────────────────────────
RELIABILITY_SERVICE_URL=http://localhost:4025
SECURITY_AI_SERVICE_URL=http://localhost:4026
DEPLOYMENT_AI_SERVICE_URL=http://localhost:4027
SELF_DELIVERY_SERVICE_URL=http://localhost:4028
ADMIN_OVERRIDE_SERVICE_URL=http://localhost:4029
SOCIAL_MEDIA_SERVICE_URL=http://localhost:4030
KYC_SERVICE_URL=http://localhost:4023
RECON_SERVICE_URL=http://localhost:4024

# Social media (OAuth tokens — NEVER raw passwords)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
INSTAGRAM_CLIENT_ID=your_instagram_client_id
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret

# VTU / Bill payments
VTU_PROVIDER_URL=https://api.vtpass.com/api
VTU_API_KEY=your_vtu_api_key
VTU_PUBLIC_KEY=your_vtu_public_key

# Deployment AI thresholds
DEPLOY_SECURITY_MIN=90
DEPLOY_RELIABILITY_MIN=90
DEPLOY_SCALABILITY_MIN=85
DEPLOY_PERFORMANCE_MIN=85
DEPLOY_READINESS_MIN=90

# Chaos engineering (NEVER enable in production)
CHAOS_ENABLED=false

# Fintech OS (Update #96)
FINTECH_DISCLAIMER_ENABLED=true
MAX_LOAN_MULTIPLIER_HARD_CAP=1.0

# Admin impersonation
ADMIN_SESSION_EXPIRY_MINS=30
MFA_REQUIRED_FOR_IMPERSONATION=true

# Nigeria network resilience
NIGERIA_QUEUE_MAX_RETRIES=10
OFFLINE_QUEUE_FLUSH_ON_RECONNECT=true
