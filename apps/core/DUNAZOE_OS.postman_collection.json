{
  "info": {
    "name": "DUNAZOE OS — Complete API Collection",
    "description": "All endpoints for DUNAZOE microservices backend. Import into Postman. Set baseUrl variable to http://localhost:3000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token",   "value": "", "type": "string" },
    { "key": "userId",  "value": "", "type": "string" },
    { "key": "vendorId","value": "", "type": "string" },
    { "key": "productId","value":"", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth Service",
      "item": [
        {
          "name": "Register User",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('token', pm.response.json().token);",
            "  pm.collectionVariables.set('userId', pm.response.json().user_id);",
            "  pm.test('Registration successful', () => pm.expect(pm.response.code).to.eq(201));",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Temidayo Folorunso\",\n  \"email\": \"ceo@dunazoe.com\",\n  \"password\": \"SecurePass2026!\",\n  \"phone\": \"08012345678\",\n  \"whatsapp\": \"08012345678\",\n  \"role\": \"customer\",\n  \"state\": \"oyo\",\n  \"city\": \"ibadan\",\n  \"town\": \"bodija\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  pm.collectionVariables.set('token', pm.response.json().token);",
            "  pm.collectionVariables.set('userId', pm.response.json().user_id);",
            "  pm.test('Login OK', () => pm.expect(pm.response.json().token).to.be.a('string'));",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ceo@dunazoe.com\",\n  \"password\": \"SecurePass2026!\"\n}" }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/verify",
            "body": { "mode": "raw", "raw": "{ \"token\": \"{{token}}\" }" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/logout",
            "body": { "mode": "raw", "raw": "{ \"token\": \"{{token}}\" }" }
          }
        }
      ]
    },

    {
      "name": "👤 User Service",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/{{userId}}",
            "body": { "mode": "raw", "raw": "{\n  \"city\": \"akure\",\n  \"state\": \"ondo\",\n  \"phone\": \"08012345678\"\n}" }
          }
        }
      ]
    },

    {
      "name": "🏪 Vendor Service",
      "item": [
        {
          "name": "Register Vendor (Pickup Station)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) pm.collectionVariables.set('vendorId', pm.response.json().vendor_id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/vendors",
            "body": { "mode": "raw", "raw": "{\n  \"business_name\": \"Adebayo Fashions Akure\",\n  \"description\": \"Premium SW Nigeria fashion store\",\n  \"type\": \"direct\",\n  \"category\": \"fashion\",\n  \"state\": \"ondo\",\n  \"city\": \"akure\",\n  \"town\": \"ilesha way\",\n  \"lat\": 7.2526,\n  \"lng\": 5.1986,\n  \"pickup_address\": \"12 Ilesha Way, Akure\",\n  \"payout_method\": \"bank\",\n  \"bank_name\": \"OPay\",\n  \"account_no\": \"8012345678\",\n  \"account_name\": \"Adebayo Fashion Store\"\n}" }
          }
        },
        {
          "name": "Approve Vendor (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/vendors/{{vendorId}}/verify"
          }
        },
        {
          "name": "Get Vendor",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/vendors/{{vendorId}}"
          }
        },
        {
          "name": "List Vendors by State",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/vendors?state=ondo&status=active",
              "query": [
                { "key": "state", "value": "ondo" },
                { "key": "status", "value": "active" }
              ]
            }
          }
        },
        {
          "name": "Register Copy Trader",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/vendors/copy-trader/register",
            "body": { "mode": "raw", "raw": "{\n  \"source_vendor_id\": \"{{vendorId}}\"\n}" }
          }
        }
      ]
    },

    {
      "name": "📦 Product Service",
      "item": [
        {
          "name": "AI Listing Assistant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
