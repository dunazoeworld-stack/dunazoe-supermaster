          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/products",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Premium Ankara Dress\",\n  \"description\": \"Authentic Ankara dress, available in all sizes. Made in Nigeria.\",\n  \"type\": \"physical\",\n  \"category\": \"fashion\",\n  \"price\": 18000,\n  \"cost\": 12000,\n  \"ajo_enabled\": true,\n  \"ajo_weeks\": 3,\n  \"images\": \"https://dunazoe.com/img/ankara1.jpg\"\n}" }
          }
        },
        {
          "name": "Browse Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?category=fashion&state=ondo&page=1",
              "query": [
                { "key": "category", "value": "fashion" },
                { "key": "state", "value": "ondo" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Copy Product (6% markup)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/products/copy",
            "body": { "mode": "raw", "raw": "{ \"product_id\": \"{{productId}}\" }" }
          }
        }
      ]
    },

