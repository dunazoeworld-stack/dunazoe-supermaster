{
  "title": "DUNAZOE OS v4 — Operations Dashboard",
  "uid": "dunazoe-ops-v4",
  "tags": ["dunazoe","operations","fintech","updates-93-96"],
  "timezone": "Africa/Lagos",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    { "id":1,"type":"stat","title":"🟢 Services Online (31)","gridPos":{"h":4,"w":4,"x":0,"y":0},
      "targets":[{"expr":"count(up{job='dunazoe-services'} == 1)","legendFormat":"Online"}],
      "options":{"colorMode":"background","thresholds":{"steps":[{"color":"red","value":0},{"color":"yellow","value":25},{"color":"green","value":31}]}}},
    { "id":2,"type":"stat","title":"💳 Payments (5m)","gridPos":{"h":4,"w":4,"x":4,"y":0},
      "targets":[{"expr":"sum(increase(http_requests_total{service='dunazoe-payment',status='200'}[5m]))"}]},
    { "id":3,"type":"stat","title":"🚨 Fraud Blocks (5m)","gridPos":{"h":4,"w":4,"x":8,"y":0},
      "targets":[{"expr":"sum(increase(dunazoe_fraud_checks_total{risk_level='high_risk'}[5m]))"}],
      "options":{"colorMode":"background","thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":5},{"color":"red","value":20}]}}},
    { "id":4,"type":"stat","title":"🔐 Security Threats (24h)","gridPos":{"h":4,"w":4,"x":12,"y":0},
      "targets":[{"expr":"increase(dunazoe_security_events_total[24h])"}],
      "options":{"colorMode":"background","thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":10},{"color":"red","value":50}]}}},
    { "id":5,"type":"stat","title":"🚀 Deploy Score","gridPos":{"h":4,"w":4,"x":16,"y":0},
      "targets":[{"expr":"dunazoe_deployment_score{type='readiness'}"}],
      "options":{"colorMode":"background","thresholds":{"steps":[{"color":"red","value":0},{"color":"yellow","value":85},{"color":"green","value":90}]}}},
    { "id":6,"type":"stat","title":"📬 Outbox Pending","gridPos":{"h":4,"w":4,"x":20,"y":0},
      "targets":[{"expr":"dunazoe_outbox_pending_events"}],
      "options":{"colorMode":"background","thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":50},{"color":"red","value":100}]}}},
    { "id":10,"type":"timeseries","title":"Request Rate by Service (req/s)","gridPos":{"h":8,"w":16,"x":0,"y":4},
      "targets":[{"expr":"sum by (service) (rate(http_requests_total{job='dunazoe-services'}[1m]))","legendFormat":"{{ service }}"}]},
    { "id":11,"type":"timeseries","title":"P95 Latency (ms)","gridPos":{"h":8,"w":8,"x":16,"y":4},
      "targets":[{"expr":"histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_seconds_bucket{job='dunazoe-services'}[5m]))) * 1000","legendFormat":"{{ service }}"}]},
    { "id":20,"type":"timeseries","title":"Fraud Detection Rate","gridPos":{"h":8,"w":12,"x":0,"y":12},
      "targets":[
        {"expr":"rate(dunazoe_fraud_checks_total{risk_level='safe'}[5m])","legendFormat":"✅ Safe"},
        {"expr":"rate(dunazoe_fraud_checks_total{risk_level='suspicious'}[5m])","legendFormat":"⚠️ Suspicious"},
        {"expr":"rate(dunazoe_fraud_checks_total{risk_level='high_risk'}[5m])","legendFormat":"🚨 High Risk"}
      ]},
    { "id":21,"type":"timeseries","title":"Security Events (Update #94)","gridPos":{"h":8,"w":12,"x":12,"y":12},
      "targets":[{"expr":"rate(dunazoe_security_events_total[5m])","legendFormat":"{{ event_type }}"}]},
    { "id":30,"type":"timeseries","title":"💰 Wallet Transactions/min","gridPos":{"h":8,"w":12,"x":0,"y":20},
      "targets":[
        {"expr":"rate(dunazoe_wallet_operations_total{operation='deposit'}[1m])","legendFormat":"Deposits"},
        {"expr":"rate(dunazoe_wallet_operations_total{operation='withdraw'}[1m])","legendFormat":"Withdrawals"}
      ]},
    { "id":31,"type":"timeseries","title":"Social Media Activity (Update #93)","gridPos":{"h":8,"w":12,"x":12,"y":20},
      "targets":[{"expr":"rate(dunazoe_social_posts_total[1h])","legendFormat":"{{ platform }}"}]}
  ],
  "time": {"from":"now-1h","to":"now"},
  "version": 4
}
