# ================================================================
# DUNAZOE Supermaster — .gitignore
# ================================================================

# Dependencies
node_modules/
**/node_modules/

# Environment files — NEVER commit these
.env
.env.docker
.env.local
.env.production
**/.env
**/.env.local
**/.env.docker
**/.env.production
!.env.example
!**/.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime
*.pid
*.seed
*.pid.lock
pids/

# Build output
dist/
build/
.next/
.cache/
.expo/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor files
.idea/
.vscode/settings.json
*.swp
*.swo
*~

# Docker
.dockerignore

# Test output
coverage/
.nyc_output/
test-results/

# PostgreSQL local data
postgres_data/

# Archives
*.tar.gz

# Attached assets (may contain pasted secrets — never commit)
attached_assets/
